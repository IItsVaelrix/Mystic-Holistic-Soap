# Optional overrides for the Saponification Bench server.
# The app runs fully offline with no external services or API keys.

# Network binding. Defaults to localhost. Set HOST=0.0.0.0 only if the app is
# protected (see the auth gate below) or otherwise not publicly reachable.
# HOST="127.0.0.1"
# PORT="3000"

# Optional HTTP Basic Auth gate. When AUTH_PASSWORD_HASH is set, every request
# must present valid credentials. Generate the hash with:
#   npm run hash-password -- "your-password"
# and set it as a real secret (e.g. `fly secrets set AUTH_PASSWORD_HASH=...`),
# not here. AUTH_USER is the (non-secret) username; empty accepts any username.
# AUTH_USER="mystic"
# AUTH_PASSWORD_HASH="saltHex:keyHex"
